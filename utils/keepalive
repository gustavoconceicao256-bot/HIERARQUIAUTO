import https from "https";

const URL = "https://hierarquiauto.onrender.com";

function acordarBot() {
  https.get(URL, (res) => {
    console.log("🔋 KeepAlive enviado:", res.statusCode);
  }).on("error", (err) => {
    console.log("❌ Erro KeepAlive:", err.message);
  });
}

// chama a cada 5 minutos
setInterval(acordarBot, 5 * 60 * 1000);

console.log("🟢 Sistema KeepAlive iniciado!");
